# _headers

# HTML pages - Allow caching for bfcache
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# For the main page specifically
/index.html
  Cache-Control: public, max-age=3600, must-revalidate

# Images - Cache for 1 year
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/studio/*
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

# CSS and JS - Cache for 1 year
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# No-cache only for livereload (development)
/livereload.js*
  Cache-Control: no-cache, no-store, must-revalidate